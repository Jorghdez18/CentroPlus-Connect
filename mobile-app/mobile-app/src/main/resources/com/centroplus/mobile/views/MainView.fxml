<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/20"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.centroplus.mobile.controllers.MainController">

    <!-- HEADER -->

    <top>

        <HBox alignment="CENTER_LEFT"
              spacing="15"
              styleClass="header">

            <padding>
                <Insets top="20" right="25" bottom="20" left="25"/>
            </padding>

            <Label text="CentroPlus Connect"
                   styleClass="titulo"/>

        </HBox>

    </top>

    <!-- CENTER -->

    <center>

        <HBox spacing="25"
              alignment="CENTER"
              styleClass="main-container">

            <padding>
                <Insets top="25" right="25" bottom="25" left="25"/>
            </padding>

            <!-- ACTIVIDADES -->

            <VBox spacing="15"
                  styleClass="card">

                <Label text="Actividades"
                       styleClass="section-title"/>

                <ListView fx:id="listaActividades"
                          prefWidth="350"
                          prefHeight="350"/>

                <Button text="Reservar Plaza"
                        onAction="#reservarActividad"
                        styleClass="primary-btn"/>

            </VBox>

            <!-- RESERVAS -->

            <VBox spacing="15"
                  styleClass="card">

                <Label text="Mis Reservas"
                       styleClass="section-title"/>

                <ListView fx:id="listaReservas"
                          prefWidth="350"
                          prefHeight="350"/>

                <HBox spacing="10">

                    <Button text="Cancelar Reserva"
                            onAction="#cancelarReserva"
                            styleClass="danger-btn"/>

                    <Button text="Enviar Incidencia"
                            onAction="#mostrarFormularioIncidencia"
                            styleClass="secondary-btn"/>

                </HBox>

            </VBox>

        </HBox>

    </center>

    <!-- FOOTER -->

    <bottom>

        <HBox alignment="CENTER"
              styleClass="footer">

            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>

            <Label text="CentroPlus Connect © 2026"/>

        </HBox>

    </bottom>

</BorderPane>