<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>

<BorderPane xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.centroplus.mobile.controllers.MainController">
    <center>
        <VBox spacing="10">
            <Label fx:id="labelTitulo" text="CentroPlus Mobile" style="-fx-font-size: 18px;"/>
            <ListView fx:id="listaActividades" prefHeight="300"/>
            <Button text="Filtrar solo Deportes" onAction="#filtrarDeportes"/>
        </VBox>
    </center>
</BorderPane>